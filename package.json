{
  "name": "@matchory/docker-swarm-deployment-action",
  "description": "A GitHub Action to deploy a Docker Swarm stack.",
  "version": "1.1.0",
  "author": {
    "name": "Moritz Friedrich",
    "email": "moritz@matchory.com",
    "url": "https://matchory.com"
  },
  "type": "module",
  "private": true,
  "homepage": "https://github.com/matchory/docker-swarm-deployment-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matchory/docker-swarm-deployment-action.git"
  },
  "bugs": {
    "url": "https://github.com/matchory/docker-swarm-deployment-action/issues"
  },
  "keywords": [
    "actions",
    "docker",
    "docker-swarm",
    "deployment",
    "cluster",
    "devops"
  ],
  "main": "src/main.ts",
  "exports": {
    ".": "./src/main.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "postversion": "npm run licensed && npm run all",
    "bundle": "npx @vercel/ncc build src/index.ts --source-map --license licenses.txt --minify --out dist --target es2022 --no-cache",
    "ci-test": "npx vitest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx @biomejs/biome check --write --unsafe",
    "format:check": "npx @biomejs/biome format",
    "lint": "npx @biomejs/biome lint",
    "licensed": "licensed cache",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npm run bundle",
    "typecheck": "npx tsc --noEmit",
    "test": "npx vitest --run",
    "all": "npm run format:write && npm run lint && npm run typecheck && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.6",
    "globals": "^17.6.0",
    "make-coverage-badge": "^1.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.6"
  }
}
